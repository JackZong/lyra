{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lyra",
  "version": "1.0.0",
  "identifier": "com.lyra.editor",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Lyra",
        "width": 1100,
        "height": 750,
        "minWidth": 600,
        "minHeight": 400,
        "decorations": true,
        "center": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["md", "markdown", "mdown", "mkd", "mdx"],
        "name": "Markdown Document",
        "role": "Editor",
        "mimeType": "text/markdown",
        "contentTypes": ["net.daringfireball.markdown"]
      },
      {
        "ext": ["txt"],
        "name": "Text Document",
        "role": "Editor",
        "mimeType": "text/plain",
        "contentTypes": ["public.plain-text"]
      }
    ]
  }
}
